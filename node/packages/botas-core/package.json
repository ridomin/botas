{
  "name": "botas-core",
  "version": "0.1.0",
  "description": "Lightweight library for building Microsoft Bot Service bots - Node.js/TypeScript",
  "type": "module",
  "license": "MIT",
  "author": "rido-min",
  "homepage": "https://github.com/rido-min/botas#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rido-min/botas.git",
    "directory": "node/packages/botas-core"
  },
  "bugs": {
    "url": "https://github.com/rido-min/botas/issues"
  },
  "keywords": [
    "bot",
    "bot-framework",
    "microsoft-teams",
    "chatbot",
    "typescript"
  ],
  "readme": "README.md",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "npx rimraf ./dist",
    "sync-version": "node scripts/sync-version.mjs",
    "build": "npm run sync-version && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "node --import tsx --test src/core-activity.spec.ts src/bot-application.spec.ts src/remove-mention-middleware.spec.ts src/teams-activity.spec.ts src/bot-auth-middleware.spec.ts src/typing-activity.spec.ts src/security-fixes.spec.ts src/p2-fixes.spec.ts src/conversation-client.spec.ts src/tracer-provider.spec.ts src/bot-application-otel.spec.ts src/otel-auth-cc.spec.ts",
    "docs": "typedoc"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "axios": "^1.15.0",
    "debug": "^4.4.3",
    "jose": "^6.2.2"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0",
    "@opentelemetry/api-logs": "^0.200.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@opentelemetry/api-logs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.216.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@types/node": "^25.6.0",
    "typedoc": "^0.28.19"
  }
}
