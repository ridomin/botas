{% extends "default/module.html.jinja2" %}

{% block head %}
{{ super() }}
<style>
  /* ── BotAS Navigation Bar ── */
  .botas-nav {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 0.5rem 1.5rem;
    background: #1b1b1f;
    border-bottom: 2px solid #ff9100;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 0.875rem;
    flex-wrap: wrap;
  }
  .botas-nav a {
    color: #ffffffde;
    text-decoration: none;
    transition: color 0.15s;
  }
  .botas-nav a:hover { color: #ff9100; }
  .botas-nav .botas-logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 1rem;
    color: #ff9100;
    margin-right: auto;
  }
  .botas-nav .botas-logo img { height: 24px; width: 24px; }
  .botas-nav .botas-back { color: #ff9100; font-size: 0.8rem; }

  /*
   * pdoc uses `.pdoc` scoped CSS variables that override `:root`.
   * We must target the same selector with !important to win.
   */
  body {
    background-color: #1b1b1f !important;
    color-scheme: dark;
  }

  /* Override pdoc's scoped variables */
  .pdoc {
    --text: #ffffffde !important;
    --muted: #a8a8b3 !important;
    --link: #ff9100 !important;
    --link-hover: #ffa833 !important;
    --accent: #252529 !important;
    --accent2: #3a3a42 !important;
    --nav-hover: rgba(255, 145, 0, 0.12) !important;
    --name: #ff9100 !important;
    --def: #ffa833 !important;
    --annotation: #ffbf66 !important;
  }

  /* Override pdoc background variable */
  :root {
    --pdoc-background: #1b1b1f !important;
  }

  nav.pdoc {
    background-color: #252529 !important;
    border-right-color: #3a3a42 !important;
  }

  /* Force dark syntax highlighting */
  .pdoc-code {
    background: #252529 !important;
  }

  header {
    background-color: #1b1b1f !important;
    color: #ffffffde !important;
  }

  header a { color: #ff9100 !important; }

  h1, h2, h3, h4, h5, h6 {
    color: #ffffffde !important;
  }
</style>
{% endblock %}

{% block body %}
<nav class="botas-nav" aria-label="BotAS site navigation">
  <a href="/" class="botas-logo">
    <img src="/logo.svg" alt="BotAS logo" />
    BotAS
  </a>
  <a href="/" class="botas-back">← Back to BotAS Docs</a>
  <a href="/">Home</a>
  <a href="/languages/dotnet">.NET Guide</a>
  <a href="/languages/nodejs">Node.js Guide</a>
  <a href="/languages/python">Python Guide</a>
</nav>
{{ super() }}
{% endblock %}
